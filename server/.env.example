# ============================================================
# Secure Cloud — Backend Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to Git
# ============================================================

# Server
NODE_ENV=development
PORT=4000
CLIENT_ORIGIN=http://localhost:5173

# Database (PostgreSQL)
DATABASE_URL=postgresql://securecloud:secret@localhost:5432/securecloud

# JWT Secrets — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=CHANGE_ME_GENERATE_A_LONG_RANDOM_STRING
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_A_DIFFERENT_LONG_RANDOM_STRING

# Storage
STORAGE_PATH=./storage

# File size limit in bytes (default 100MB)
MAX_FILE_SIZE=104857600
