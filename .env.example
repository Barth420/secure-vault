# ============================================================
# Root .env — copy this to .env and fill in values
# Required for docker-compose
# ============================================================

# PostgreSQL
POSTGRES_PASSWORD=change_this_password

# JWT — generate with:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=generate_a_64_byte_hex_string_here
JWT_REFRESH_SECRET=generate_a_different_64_byte_hex_string_here

# Frontend origin (for CORS)
CLIENT_ORIGIN=http://localhost

# Port NGINX listens on
HTTP_PORT=80

# Max upload size in bytes (100MB default)
MAX_FILE_SIZE=104857600
